# ---
# name: TestGoldenMasterDistributionVariants.test_tmdd_core
  '''
  # APMODE generated model: golden_test_model_id_0
  function() {
    ini({
      # Structural parameters
      lka <- log(1.0)
      lV <- log(50.0)
      lR0 <- log(10.0)
      lkon <- log(0.1)
      lkoff <- log(0.01)
      lkint <- log(0.05)
      lCL <- log(5.0)
      
      # Inter-individual variability
      eta.CL ~ 0.1
      eta.V ~ 0.1
      
      # Residual error
      prop.sd <- 0.1
    })
    model({
      # Back-transform parameters
      ka <- exp(lka)
      V <- exp(lV + eta.V)
      R0 <- exp(lR0)
      kon <- exp(lkon)
      koff <- exp(lkoff)
      kint <- exp(lkint)
      kdeg <- koff  # receptor degradation ~ koff initial estimate
      ksyn <- kdeg * R0  # receptor synthesis at baseline
      kel <- CL / V  # elimination rate constant
      CL <- exp(lCL + eta.CL)
      
      # Compartment dynamics
      d/dt(depot) <- -ka * depot
      # TMDD full binding model (Mager & Jusko 2001)
      L <- centr / V  # drug concentration
      d/dt(centr) <- ka * depot - kel * centr - kon * L * R * V + koff * RC * V
      d/dt(R) <- ksyn - kdeg * R - kon * L * R + koff * RC
      d/dt(RC) <- kon * L * R - koff * RC - kint * RC
      R(0) <- R0
      cp <- centr / V
      
      # Observation model
      cp ~ prop(prop.sd)
    })
  }
  '''
# ---
# name: TestGoldenMasterDistributionVariants.test_tmdd_qss
  '''
  # APMODE generated model: golden_test_model_id_0
  function() {
    ini({
      # Structural parameters
      lka <- log(1.0)
      lV <- log(50.0)
      lR0 <- log(10.0)
      lKD <- log(0.5)
      lkint <- log(0.05)
      lCL <- log(5.0)
      
      # Inter-individual variability
      eta.CL ~ 0.1
      eta.V ~ 0.1
      
      # Residual error
      prop.sd <- 0.1
    })
    model({
      # Back-transform parameters
      ka <- exp(lka)
      V <- exp(lV + eta.V)
      R0 <- exp(lR0)
      KD <- exp(lKD)
      kint <- exp(lkint)
      kdeg <- kint  # receptor degradation initial estimate
      ksyn <- kdeg * R0
      kel <- CL / V  # elimination rate constant
      CL <- exp(lCL + eta.CL)
      
      # Compartment dynamics
      d/dt(depot) <- -ka * depot
      # TMDD quasi-steady-state (Gibiansky et al. 2008)
      # KSS = (koff + kint)/kon; KD = koff/kon.
      # When kint << koff, KSS ≈ KD. When kint is significant,
      # KSS > KD; using KD underestimates KSS, which can
      # overestimate complex formation and target-mediated elimination.
      # The TMDDQSS DSL module estimates KD directly; to use the
      # full KSS, convert to TMDDCore (kon, koff, kint) instead.
      KSS <- KD  # QSS approximation: KSS ≈ KD
      # Convert total drug amount to concentration
      Ctot <- Atot / V
      # Algebraic QSS: solve for free concentrations
      Cfree <- 0.5 * ((Ctot - Rtot - KSS) + sqrt((Ctot - Rtot - KSS)^2 + 4 * KSS * Ctot))
      Rfree <- Rtot * KSS / (KSS + Cfree)
      RC <- Ctot - Cfree
      d/dt(Atot) <- ka * depot - kel * Cfree * V - kint * RC * V
      d/dt(Rtot) <- ksyn - kdeg * Rfree - kint * RC
      Atot(0) <- 0
      Rtot(0) <- R0
      cp <- Cfree
      
      # Observation model
      cp ~ prop(prop.sd)
    })
  }
  '''
