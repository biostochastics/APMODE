# name: TestGoldenMasterAbsorptionVariants.test_mixed_first_zero
  '''
  # APMODE generated model: golden_test_model_id_0
  function() {
    ini({
      # Structural parameters
      lka <- log(1.0)
      ldur <- log(0.5)
      logit_frac <- log(0.6 / (1 - 0.6))
      lV <- log(70.0)
      lCL <- log(5.0)
      
      # Inter-individual variability
      eta.CL ~ 0.1
      eta.V ~ 0.1
      
      # Residual error
      prop.sd <- 0.1
    })
    model({
      # Back-transform parameters
      ka <- exp(lka)
      dur <- exp(ldur)
      frac <- 1 / (1 + exp(-(logit_frac)))
      V <- exp(lV + eta.V)
      CL <- exp(lCL + eta.CL)
      
      # Compartment dynamics
      d/dt(depot_fo) <- -ka * depot_fo
      dur(depot_zo) <- dur
      d/dt(depot_zo) <- -depot_zo
      f(depot_fo) <- frac
      f(depot_zo) <- 1 - frac
      d/dt(centr) <- ka * depot_fo + depot_zo - CL / V * centr
      cp <- centr / V
      
      # Observation model
      cp ~ prop(prop.sd)
    })
  }
  '''
