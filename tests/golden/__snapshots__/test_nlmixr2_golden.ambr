# name: TestGoldenMasterComplex.test_2cmt_mm_block_covariate
  '''
  # APMODE generated model: golden_test_model_id_0
  function() {
    ini({
      # Structural parameters
      lka <- log(1.5)
      ltlag <- log(0.3)
      lV1 <- log(30.0)
      lV2 <- log(40.0)
      lQ <- log(5.0)
      lCL <- log(2.0)
      lVmax <- log(50.0)
      lKm <- log(5.0)
      
      # Covariate coefficients
      beta_CL_WT <- 0.75
      beta_V1_WT <- 0.75
      
      # Inter-individual variability
      eta.CL + eta.V1 + eta.ka ~ c(
        0.1, 0.01, 0.1, 0.01, 0.01, 0.1
      )
      
      # Residual error
      prop.sd <- 0.1
      add.sd <- 0.5
    })
    model({
      # Back-transform parameters
      ka <- exp(lka + eta.ka)
      tlag <- exp(ltlag)
      V1 <- exp(lV1 + eta.V1 + beta_V1_WT * log(WT / 70))
      V2 <- exp(lV2)
      Q <- exp(lQ)
      CL <- exp(lCL + eta.CL + beta_CL_WT * log(WT / 70))
      Vmax <- exp(lVmax)
      Km <- exp(lKm)
      
      # Compartment dynamics
      alag(depot) <- tlag
      d/dt(depot) <- -ka * depot
      d/dt(centr) <- ka * depot - (CL / V1 * centr + Vmax * (centr/V1) / (Km + centr/V1)) - Q / V1 * centr + Q / V2 * periph
      d/dt(periph) <- Q / V1 * centr - Q / V2 * periph
      cp <- centr / V1
      
      # Observation model
      cp ~ prop(prop.sd) + add(add.sd)
    })
  }
  '''
