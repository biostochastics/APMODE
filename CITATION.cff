    given-names: Sergey A.
    affiliation: Biostochastics
version: 0.5.0-rc2
date-released: 2026-04-17
license: GPL-2.0-or-later
repository-code: "https://github.com/biostochastics/apmode"
url: "https://github.com/biostochastics/apmode"
keywords:
