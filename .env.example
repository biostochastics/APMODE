# APMODE Environment Variables
# Copy to .env and fill in your keys.
# Only set the provider(s) you plan to use.

# --- LLM Provider API Keys (for agentic backend) ---

# Anthropic (default provider for --agentic)
ANTHROPIC_API_KEY=

# OpenAI (for gpt-4o, o3-mini, etc.)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# OpenRouter (set OPENAI_API_KEY to your OpenRouter key)
# OPENAI_API_KEY=sk-or-...

# Ollama (local inference — no key needed)
# OLLAMA_HOST=http://localhost:11434

# --- Optional: Langfuse (self-hosted prompt/cost logging, Phase 3+) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000
